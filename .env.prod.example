# Copy to .env in the repo root (same directory as docker-compose.prod.yml)
# and fill in real values. This file is read by `docker compose -f
# docker-compose.prod.yml ...` automatically -- no --env-file flag needed as
# long as it's named .env and sits next to the compose file.

# ---- Domains (must have DNS A records pointing at this VM's public IP
# before starting Caddy, or the Let's Encrypt HTTP-01 challenge will fail) ----
APP_DOMAIN=app.example.com
PORTAL_DOMAIN=portal.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# ---- Database ----
# DB_MIGRATOR_PASSWORD is the postgres superuser password (owns the schema,
# runs migrations). DB_APP_PASSWORD is a separate role the running app
# connects as, bound by row-level security -- generate two different,
# strong random values, e.g. `openssl rand -base64 32`.
DB_MIGRATOR_PASSWORD=changeme-generate-a-real-password
DB_APP_PASSWORD=changeme-generate-a-different-password

# ---- Auth ----
# Signs every JWT (agent login + portal login/register). Generate with:
#   openssl rand -base64 48
JWT_SECRET=changeme-generate-a-real-secret
JWT_EXPIRES_IN=12h

# Shared secret for POST /internal/tickets/from_alert (Module 2 will call
# this once it exists). Generate the same way as JWT_SECRET.
INTERNAL_API_KEY=changeme-generate-a-real-secret

# ---- Optional: the first tenant's id, pre-fills the portal's tenant field
# so visitors never see it. Leave blank until you've created a tenant (see
# the deployment guide) and come back to set this. ----
DEFAULT_TENANT_ID=

# ---- Optional: outbound email (ticket notifications). Leave EMAIL_TRANSPORT
# as "json" (logs instead of sending) until a real SMTP provider is wired up. ----
EMAIL_TRANSPORT=json
SMTP_FROM=notifications@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ---- Optional: email intake (turns inbound mail into tickets). Off by
# default -- turn on once a real mailbox is ready. ----
EMAIL_INTAKE_ENABLED=false
EMAIL_INTAKE_TENANT_ID=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# ---- Optional: portal OAuth (Google/Facebook). Leave blank -- the portal's
# OAuth buttons stay disabled until real app credentials are set here. ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# ---- Optional: one-time Freshdesk migration (see docs, run via
# `docker compose -f docker-compose.prod.yml exec api pnpm migrate:freshdesk`) ----
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
MIGRATION_TENANT_ID=
