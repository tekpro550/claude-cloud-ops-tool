# For local testing only (docker-compose.local.yml) -- these values never
# leave your machine, so weak/placeholder secrets are fine here, unlike
# .env.prod.example. Copy to .env in this directory.
#
#   cp .env.local.example .env

# Referenced by docker-compose.prod.yml's CORS_ORIGIN default and Caddyfile,
# but docker-compose.local.yml overrides both to use localhost directly --
# these three just need to be *set* to something so compose doesn't warn
# about missing variables. Not actually used when testing locally.
APP_DOMAIN=localhost
PORTAL_DOMAIN=localhost
API_DOMAIN=localhost
ACME_EMAIL=test@localhost

DB_MIGRATOR_PASSWORD=local-test-only
DB_APP_PASSWORD=local-test-only-app

JWT_SECRET=local-test-only-jwt-secret
JWT_EXPIRES_IN=12h
INTERNAL_API_KEY=local-test-only-internal-key

DEFAULT_TENANT_ID=

EMAIL_TRANSPORT=json
SMTP_FROM=notifications@localhost
