DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_ops_tool

# Owns the schema, runs migrations, bypasses RLS. Never used by the running app.
DB_MIGRATOR_USER=postgres
DB_MIGRATOR_PASSWORD=postgres

# What the NestJS app actually connects as. Bound by RLS policies.
DB_APP_USER=app_user
DB_APP_PASSWORD=app_user_dev_password

REDIS_HOST=localhost
REDIS_PORT=6379

# "json" composes and validates messages without sending (default, safe for
# local/dev). Set "smtp" once a real provider (SendGrid/SES) is configured.
EMAIL_TRANSPORT=json
SMTP_FROM=notifications@cloud-ops-tool.local
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Comma-separated origins allowed to call the API from a browser. Defaults to
# the agent app's and customer portal's Vite dev servers.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Email intake: polls one IMAP mailbox and turns unseen messages into
# tickets. Disabled by default -- no real mailbox credentials exist yet.
# Pilot mailbox per section 8 of the Module 1 doc: cloud.support@tekprocloud.com
EMAIL_INTAKE_ENABLED=false
EMAIL_INTAKE_TENANT_ID=
EMAIL_INTAKE_POLL_INTERVAL_MS=30000
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=cloud.support@tekprocloud.com
IMAP_PASSWORD=

# How often the SLA overdue sweep scans every tenant for newly-breached
# first-response/resolution targets.
SLA_SWEEP_INTERVAL_MS=60000

# Shared-secret stand-in for real service-to-service auth on internal,
# non-browser endpoints (POST /internal/tickets/from_alert).
INTERNAL_API_KEY=dev-internal-api-key

# Signs JWTs issued by /auth/login (agents) and /portal/auth/login|register
# (contacts). Dev-only value -- generate and set a real secret before any
# real deployment.
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=12h

# Google/Facebook OAuth for the customer portal. Left blank -- no real app
# credentials exist yet, so the OAuth buttons are scaffolded but disabled
# until these are set (see PortalAuthController).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# One-time Freshdesk -> Cloud Ops Tool migration (section 9 of the Module 1
# doc, run via `pnpm migrate:freshdesk`). No real credentials exist yet.
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
MIGRATION_TENANT_ID=
