DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_ops_tool

# Owns the schema, runs migrations, bypasses RLS. Never used by the running app.
DB_MIGRATOR_USER=postgres
DB_MIGRATOR_PASSWORD=postgres

# What the NestJS app actually connects as. Bound by RLS policies.
DB_APP_USER=app_user
DB_APP_PASSWORD=app_user_dev_password

REDIS_HOST=localhost
REDIS_PORT=6379
