VITE_API_BASE_URL=http://localhost:3000/api/v1

# There's no domain-based tenant resolution yet (see the backend's
# TenantHeaderGuard) -- real deployment would resolve the tenant from the
# portal's own subdomain/custom domain. Until then, tenant zero's id is
# baked in here as a default; the login/register/submit pages let a visitor
# override it, same escape hatch the agent app's tenant-id field provides.
VITE_DEFAULT_TENANT_ID=
